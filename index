<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Questionario Nutrizione e TDEE</title>
  <style>
    :root {
      --bg: #f6f7f9;
      --card: #ffffff;
      --text: #1f2937;
      --muted: #6b7280;
      --border: #d1d5db;
      --accent: #2563eb;
      --accent-soft: #dbeafe;
      --warning: #fff7ed;
      --warning-border: #fdba74;
      --radius: 16px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
    }

    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 24px;
    }

    header {
      background: linear-gradient(135deg, #1d4ed8, #38bdf8);
      color: white;
      padding: 32px;
      border-radius: var(--radius);
      margin-bottom: 24px;
    }

    header h1 {
      margin: 0 0 8px;
      font-size: 2rem;
    }

    header p {
      margin: 0;
      opacity: 0.95;
      max-width: 760px;
    }

    .grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 24px;
      align-items: start;
    }

    @media (max-width: 900px) {
      .grid { grid-template-columns: 1fr; }
    }

    section, .output-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 22px;
      margin-bottom: 18px;
      box-shadow: 0 8px 30px rgba(15, 23, 42, 0.06);
    }

    h2 {
      margin: 0 0 16px;
      font-size: 1.25rem;
    }

    h3 {
      margin: 20px 0 10px;
      font-size: 1rem;
    }

    label {
      display: block;
      font-weight: 650;
      margin-bottom: 6px;
    }

    .field {
      margin-bottom: 16px;
    }

    input, select, textarea {
      width: 100%;
      padding: 11px 12px;
      border: 1px solid var(--border);
      border-radius: 10px;
      font: inherit;
      background: white;
    }

    textarea {
      min-height: 80px;
      resize: vertical;
    }

    .row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }

    .row-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }

    @media (max-width: 700px) {
      .row, .row-3 { grid-template-columns: 1fr; }
    }

    .hint {
      color: var(--muted);
      font-size: 0.9rem;
      margin-top: 4px;
    }

    button {
      border: 0;
      border-radius: 12px;
      padding: 13px 18px;
      font-weight: 750;
      cursor: pointer;
      font-size: 1rem;
    }

    .primary {
      background: var(--accent);
      color: white;
    }

    .secondary {
      background: var(--accent-soft);
      color: #1e40af;
    }

    .button-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 8px;
    }

    .sticky {
      position: sticky;
      top: 20px;
    }

    .metric {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      padding: 12px 0;
      border-bottom: 1px solid #e5e7eb;
    }

    .metric:last-child { border-bottom: 0; }

    .metric strong { font-size: 1.05rem; }

    .pill {
      display: inline-block;
      padding: 4px 9px;
      border-radius: 999px;
      background: #eef2ff;
      color: #3730a3;
      font-size: 0.85rem;
      font-weight: 700;
      margin: 4px 4px 0 0;
    }

    .warning {
      background: var(--warning);
      border: 1px solid var(--warning-border);
      padding: 14px;
      border-radius: 12px;
      margin-top: 14px;
    }

    pre {
      white-space: pre-wrap;
      background: #111827;
      color: #f9fafb;
      padding: 16px;
      border-radius: 12px;
      overflow-x: auto;
      font-size: 0.92rem;
    }

    .small {
      font-size: 0.9rem;
      color: var(--muted);
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Questionario nutrizione, abitudini e TDEE</h1>
      <p>Raccoglie dati semplici su stato attuale, movimento, alimentazione, digestione, sonno ed energia. Calcola BMR, TDEE base, TDEE aggiustato e genera un riepilogo copiabile.</p>
    </header>

    <div class="grid">
      <main>
        <section>
          <h2>1. Dati base</h2>
          <div class="row-3">
            <div class="field">
              <label>Nome</label>
              <input id="nome" type="text" placeholder="Es. Mario" />
            </div>
            <div class="field">
              <label>Età</label>
              <input id="eta" type="number" min="10" max="100" />
            </div>
            <div class="field">
              <label>Sesso biologico</label>
              <select id="sesso">
                <option value="male">Uomo</option>
                <option value="female">Donna</option>
              </select>
            </div>
          </div>

          <div class="row-3">
            <div class="field">
              <label>Altezza cm</label>
              <input id="altezza" type="number" min="120" max="230" />
            </div>
            <div class="field">
              <label>Peso kg</label>
              <input id="peso" type="number" min="30" max="250" step="0.1" />
            </div>
            <div class="field">
              <label>Circonferenza vita cm</label>
              <input id="vita" type="number" min="40" max="180" step="0.1" />
              <div class="hint">Opzionale, ma utile per monitoraggio.</div>
            </div>
          </div>

          <div class="field">
            <label>Obiettivo principale</label>
            <select id="obiettivo">
              <option>Dimagrimento</option>
              <option>Ricomposizione corporea</option>
              <option>Aumento massa</option>
              <option>Performance sportiva</option>
              <option>Salute generale</option>
              <option>Migliorare digestione/intestino</option>
              <option>Migliorare energia e sonno</option>
            </select>
          </div>
        </section>

        <section>
          <h2>2. Movimento e attività</h2>
          <div class="field">
            <label>Lavoro / studio quotidiano</label>
            <select id="lavoro">
              <option value="sedentario">Seduto quasi sempre</option>
              <option value="seduto_attivo">Seduto ma mi alzo spesso</option>
              <option value="in_piedi">In piedi molte ore</option>
              <option value="attivo">Molto attivo fisicamente</option>
              <option value="pesante">Lavoro pesante/manuale</option>
            </select>
          </div>

          <div class="row">
            <div class="field">
              <label>Passi medi giornalieri</label>
              <select id="passi">
                <option value="lt3000">&lt; 3000</option>
                <option value="3000_5000">3000–5000</option>
                <option value="5000_8000">5000–8000</option>
                <option value="8000_12000">8000–12000</option>
                <option value="gt12000">&gt; 12000</option>
              </select>
            </div>
            <div class="field">
              <label>Allenamenti a settimana</label>
              <select id="allenamenti">
                <option value="0">0</option>
                <option value="1_2">1–2</option>
                <option value="3_4">3–4</option>
                <option value="5plus">5+</option>
              </select>
            </div>
          </div>

          <div class="row">
            <div class="field">
              <label>Tipo allenamento prevalente</label>
              <select id="tipoAllenamento">
                <option>Nessuno</option>
                <option>Pesi / bodybuilding</option>
                <option>Powerlifting / pesistica</option>
                <option>Crossfit / funzionale</option>
                <option>Corsa</option>
                <option>Bici</option>
                <option>Nuoto</option>
                <option>Sport di squadra</option>
                <option>Camminata</option>
                <option>Altro</option>
              </select>
            </div>
            <div class="field">
              <label>Intensità media</label>
              <select id="intensita">
                <option value="leggera">Leggera</option>
                <option value="moderata">Moderata</option>
                <option value="alta">Alta</option>
              </select>
            </div>
          </div>

          <div class="field">
            <label>Durata media allenamento</label>
            <select id="durata">
              <option value="lt45">&lt; 45 min</option>
              <option value="45_75">45–75 min</option>
              <option value="gt75">&gt; 75 min</option>
            </select>
          </div>
        </section>

        <section>
          <h2>3. Peso, fame ed energia</h2>
          <div class="row">
            <div class="field">
              <label>Negli ultimi 2–3 mesi il peso è</label>
              <select id="trendPeso">
                <option value="stabile">Stabile</option>
                <option value="salito">Salito</option>
                <option value="sceso">Sceso</option>
                <option value="non_so">Non so</option>
              </select>
            </div>
            <div class="field">
              <label>Kcal note di mantenimento/perdita</label>
              <input id="kcalNote" type="number" min="800" max="6000" placeholder="Opzionale" />
              <div class="hint">Se sa che con X kcal mantiene/dimagrisce, scriverlo qui.</div>
            </div>
          </div>

          <div class="row-3">
            <div class="field">
              <label>Fame generale</label>
              <select id="fame">
                <option value="bassa">Bassa</option>
                <option value="normale">Normale</option>
                <option value="alta">Alta</option>
                <option value="molto_alta">Sempre fame</option>
              </select>
            </div>
            <div class="field">
              <label>Energia 1–10</label>
              <input id="energia" type="number" min="1" max="10" value="7" />
            </div>
            <div class="field">
              <label>Stress 1–10</label>
              <input id="stress" type="number" min="1" max="10" value="5" />
            </div>
          </div>
        </section>

        <section>
          <h2>4. Alimentazione e abitudini</h2>
          <div class="row-3">
            <div class="field">
              <label>Pasti al giorno</label>
              <select id="pasti">
                <option>1–2</option>
                <option>3</option>
                <option>4</option>
                <option>5+</option>
              </select>
            </div>
            <div class="field">
              <label>Verdura/frutta</label>
              <select id="fibre">
                <option value="quasi_mai">Quasi mai</option>
                <option value="1">1 volta/die</option>
                <option value="2">2 volte/die</option>
                <option value="3plus">3+ volte/die</option>
              </select>
            </div>
            <div class="field">
              <label>Proteine nei pasti</label>
              <select id="proteine">
                <option value="rare">Rare</option>
                <option value="alcuni">Alcuni pasti</option>
                <option value="spesso">Spesso</option>
                <option value="sempre">Quasi ogni pasto</option>
              </select>
            </div>
          </div>

          <div class="row-3">
            <div class="field">
              <label>Acqua al giorno</label>
              <select id="acqua">
                <option value="lt1">&lt; 1 L</option>
                <option value="1_15">1–1.5 L</option>
                <option value="15_2">1.5–2 L</option>
                <option value="2_3">2–3 L</option>
                <option value="gt3">&gt; 3 L</option>
              </select>
            </div>
            <div class="field">
              <label>Caffè / caffeina</label>
              <select id="caffe">
                <option value="0">0</option>
                <option value="1">1</option>
                <option value="2_3">2–3</option>
                <option value="4plus">4+</option>
              </select>
            </div>
            <div class="field">
              <label>Alcol</label>
              <select id="alcol">
                <option value="mai">Mai</option>
                <option value="occasionale">Occasionale</option>
                <option value="weekend">Weekend</option>
                <option value="frequente">Frequente</option>
              </select>
            </div>
          </div>
        </section>

        <section>
          <h2>5. Digestione, intestino e tolleranze</h2>
          <div class="row">
            <div class="field">
              <label>Gonfiore</label>
              <select id="gonfiore">
                <option value="mai">Mai</option>
                <option value="raro">Raro</option>
                <option value="frequente">Frequente</option>
                <option value="quotidiano">Quotidiano</option>
              </select>
            </div>
            <div class="field">
              <label>Regolarità intestinale</label>
              <select id="caccaFreq">
                <option value="lt3week">&lt; 3 volte/settimana</option>
                <option value="ogni_1_2">Ogni 1–2 giorni</option>
                <option value="daily">1 volta al giorno</option>
                <option value="2plus">2+ volte al giorno</option>
              </select>
            </div>
          </div>

          <div class="field">
            <label>Qualità feci semplificata</label>
            <select id="caccaQualita">
              <option value="dure">Dure / palline</option>
              <option value="normali">Compatte normali</option>
              <option value="morbide">Morbide</option>
              <option value="diarroiche">Diarroiche</option>
            </select>
          </div>

          <div class="field">
            <label>Alimenti che peggiorano digestione/intestino</label>
            <textarea id="alimentiProblema" placeholder="Es. latticini, legumi, glutine, cipolla, pasti molto grassi..."></textarea>
          </div>

          <div class="field">
            <label>Allergie/intolleranze diagnosticate o sospette</label>
            <textarea id="intolleranze" placeholder="Specificare se diagnosticate o solo sospette"></textarea>
          </div>
        </section>

        <section>
          <h2>6. Sonno e recupero</h2>
          <div class="row-3">
            <div class="field">
              <label>Ore sonno medie</label>
              <select id="sonnoOre">
                <option value="lt5">&lt; 5</option>
                <option value="5_6">5–6</option>
                <option value="6_7">6–7</option>
                <option value="7_8">7–8</option>
                <option value="gt8">&gt; 8</option>
              </select>
            </div>
            <div class="field">
              <label>Qualità sonno 1–10</label>
              <input id="sonnoQualita" type="number" min="1" max="10" value="7" />
            </div>
            <div class="field">
              <label>Risveglio</label>
              <select id="risveglio">
                <option value="riposato">Riposato</option>
                <option value="stanco">Stanco</option>
                <option value="interrotto">Risvegli notturni</option>
                <option value="fame">Con fame</option>
              </select>
            </div>
          </div>
        </section>

        <section>
          <h2>7. Note libere</h2>
          <div class="field">
            <label>Note importanti</label>
            <textarea id="note" placeholder="Farmaci, turni, ciclo, infortuni, pasti fuori casa, preferenze alimentari, vincoli economici..."></textarea>
          </div>

          <div class="button-row">
            <button class="primary" onclick="calcola()">Calcola output</button>
            <button class="secondary" onclick="copiaOutput()">Copia riepilogo</button>
            <button class="secondary" onclick="scaricaJSON()">Scarica dati JSON</button>
          </div>
        </section>
      </main>

      <aside class="sticky">
        <div class="output-card">
          <h2>Output</h2>
          <div id="metriche">
            <p class="small">Compila i dati e premi “Calcola output”.</p>
          </div>
        </div>

        <div class="output-card">
          <h2>Riepilogo copiabile</h2>
          <pre id="riepilogo">Nessun output ancora.</pre>
        </div>
      </aside>
    </div>
  </div>

  <script>
    function val(id) {
      return document.getElementById(id).value;
    }

    function num(id) {
      const v = parseFloat(val(id));
      return Number.isFinite(v) ? v : null;
    }

    function mifflin(peso, altezza, eta, sesso) {
      if (!peso || !altezza || !eta) return null;
      const base = 10 * peso + 6.25 * altezza - 5 * eta;
      return sesso === "male" ? base + 5 : base - 161;
    }

    function moltiplicatoreBase() {
      let m = 1.2;

      const lavoro = val("lavoro");
      const passi = val("passi");
      const allenamenti = val("allenamenti");
      const intensita = val("intensita");
      const durata = val("durata");

      const lavoroAdd = {
        sedentario: 0,
        seduto_attivo: 0.05,
        in_piedi: 0.12,
        attivo: 0.22,
        pesante: 0.35
      };

      const passiAdd = {
        lt3000: -0.03,
        "3000_5000": 0,
        "5000_8000": 0.06,
        "8000_12000": 0.12,
        gt12000: 0.20
      };

      const allenamentiAdd = {
        "0": 0,
        "1_2": 0.06,
        "3_4": 0.13,
        "5plus": 0.20
      };

      m += lavoroAdd[lavoro] || 0;
      m += passiAdd[passi] || 0;
      m += allenamentiAdd[allenamenti] || 0;

      if (allenamenti !== "0") {
        if (intensita === "alta") m += 0.03;
        if (intensita === "leggera") m -= 0.02;
        if (durata === "gt75") m += 0.03;
        if (durata === "lt45") m -= 0.02;
      }

      return Math.max(1.15, Math.min(m, 2.15));
    }

    function aggiustamentoTDEE() {
      let adj = 0;
      const motivi = [];

      const sonnoOre = val("sonnoOre");
      const sonnoQualita = num("sonnoQualita");
      const energia = num("energia");
      const stress = num("stress");
      const trendPeso = val("trendPeso");
      const fame = val("fame");

      if (sonnoOre === "lt5" || sonnoQualita <= 4) {
        adj -= 0.03;
        motivi.push("sonno scarso: prudenza sul deficit e sul carico complessivo");
      }

      if (energia !== null && energia <= 4) {
        adj -= 0.02;
        motivi.push("energia bassa: possibile recupero o introito non ottimale");
      }

      if (stress !== null && stress >= 8) {
        adj -= 0.02;
        motivi.push("stress alto: possibile riduzione NEAT/aderenza e maggiore fame");
      }

      if (trendPeso === "salito") {
        adj += 0.02;
        motivi.push("peso recente in salita: verificare introito reale e mantenimento");
      }

      if (trendPeso === "sceso") {
        adj -= 0.02;
        motivi.push("peso recente in discesa: possibile TDEE effettivo o introito diverso dal dichiarato");
      }

      if (fame === "molto_alta") {
        motivi.push("fame molto alta: utile aumentare sazietà, proteine, fibre e distribuzione pasti");
      }

      return { adj, motivi };
    }

    function flagProfilo() {
      const flags = [];

      if (["frequente", "quotidiano"].includes(val("gonfiore"))) flags.push("gonfiore frequente");
      if (["lt3week"].includes(val("caccaFreq"))) flags.push("stitichezza / bassa regolarità");
      if (["diarroiche"].includes(val("caccaQualita"))) flags.push("feci diarroiche");
      if (["dure"].includes(val("caccaQualita"))) flags.push("feci dure / possibile bassa idratazione o fibre");
      if (["quasi_mai"].includes(val("fibre"))) flags.push("bassa quota di frutta/verdura/fibre");
      if (["lt1", "1_15"].includes(val("acqua"))) flags.push("idratazione probabilmente bassa");
      if (val("caffe") === "4plus") flags.push("caffeina alta");
      if (["weekend", "frequente"].includes(val("alcol"))) flags.push("alcol da considerare nel bilancio calorico e recupero");
      if (["lt5", "5_6"].includes(val("sonnoOre"))) flags.push("sonno corto");
      if ((num("stress") || 0) >= 8) flags.push("stress alto");

      return flags;
    }

    function affidabilita(kcalNote) {
      let score = 0;
      if (kcalNote) score += 2;
      if (val("passi") !== "lt3000") score += 1;
      if (val("trendPeso") !== "non_so") score += 1;
      if (num("vita")) score += 1;

      if (score >= 4) return "Alta";
      if (score >= 2) return "Media";
      return "Bassa";
    }

    function raccogliDati() {
      const ids = [
        "nome", "eta", "sesso", "altezza", "peso", "vita", "obiettivo", "lavoro", "passi",
        "allenamenti", "tipoAllenamento", "intensita", "durata", "trendPeso", "kcalNote",
        "fame", "energia", "stress", "pasti", "fibre", "proteine", "acqua", "caffe", "alcol",
        "gonfiore", "caccaFreq", "caccaQualita", "alimentiProblema", "intolleranze",
        "sonnoOre", "sonnoQualita", "risveglio", "note"
      ];

      const data = {};
      ids.forEach(id => data[id] = val(id));
      return data;
    }

    function calcola() {
      const peso = num("peso");
      const altezza = num("altezza");
      const eta = num("eta");
      const sesso = val("sesso");
      const kcalNote = num("kcalNote");

      const bmr = mifflin(peso, altezza, eta, sesso);
      if (!bmr) {
        alert("Inserisci almeno età, altezza e peso.");
        return;
      }

      const mult = moltiplicatoreBase();
      const tdeeBase = bmr * mult;
      const adj = aggiustamentoTDEE();
      const tdeeAggiustato = tdeeBase * (1 + adj.adj);

      let tdeeFinale = tdeeAggiustato;
      let notaKcal = "";

      if (kcalNote) {
        tdeeFinale = (tdeeAggiustato * 0.65) + (kcalNote * 0.35);
        notaKcal = "È stato considerato anche il dato kcal noto, pesato al 35%.";
      }

      const flags = flagProfilo();
      const aff = affidabilita(kcalNote);
      const rangeLow = Math.round(tdeeFinale - 100);
      const rangeHigh = Math.round(tdeeFinale + 100);

      document.getElementById("metriche").innerHTML = `
        <div class="metric"><span>BMR stimato</span><strong>${Math.round(bmr)} kcal</strong></div>
        <div class="metric"><span>Moltiplicatore attività</span><strong>${mult.toFixed(2)}</strong></div>
        <div class="metric"><span>TDEE base</span><strong>${Math.round(tdeeBase)} kcal</strong></div>
        <div class="metric"><span>TDEE aggiustato</span><strong>${Math.round(tdeeFinale)} kcal</strong></div>
        <div class="metric"><span>Range operativo</span><strong>${rangeLow}–${rangeHigh} kcal</strong></div>
        <div class="metric"><span>Affidabilità stima</span><strong>${aff}</strong></div>
        <div class="warning">
          <strong>Flag principali</strong><br>
          ${flags.length ? flags.map(f => `<span class="pill">${f}</span>`).join("") : "Nessun flag evidente."}
        </div>
      `;

      const dati = raccogliDati();
      const riepilogo = `QUESTIONARIO NUTRIZIONE / TDEE

Nome: ${dati.nome || "-"}
